# Copy this file to .env and fill in your values

# Flask environment: development or production
FLASK_ENV=development

# REQUIRED in production: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY

# Admin dashboard password
ADMIN_PASSWORD=change_me_strong_password

# Optional: PostgreSQL URL for production (leave blank to use SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_entry

# Optional: Redis URL for distributed rate limiting
# REDIS_URL=redis://localhost:6379/0

# Port for Gunicorn
PORT=5000
